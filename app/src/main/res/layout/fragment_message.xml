<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whiteDay">

    <!-- ====================== TAB ROW ====================== -->
    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:background="@color/whiteDay"
        app:layout_constraintTop_toTopOf="parent">
        <!-- TAB: Shop -->
        <LinearLayout
            android:id="@+id/tabShop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/whiteDay"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="16dp">

            <TextView
                android:id="@+id/tabShop_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Shop"
                android:layout_marginBottom="8dp"
                android:textColor="@color/darkerDay"
                android:textSize="@dimen/text_16"
                android:textStyle="normal" />

            <View
                android:id="@+id/indicatorShop"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/highLight4" />
        </LinearLayout>
        <!-- TAB: Khách -->
        <LinearLayout
            android:id="@+id/tabKhach"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:background="@color/whiteDay"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <TextView
                android:id="@+id/tabKhach_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_vertical"
                android:text="Khách"
                android:layout_marginBottom="8dp"
                android:textColor="@color/darkerDay"
                android:textSize="@dimen/text_16"
                android:textStyle="normal" />

            <View
                android:id="@+id/indicatorKhach"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/highLight4" />  <!-- màu gạch dưới khi được chọn -->
        </LinearLayout>
    </LinearLayout>

    <!-- ====================== FRAGMENT CONTAINER ====================== -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabContainer"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>